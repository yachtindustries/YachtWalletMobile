{
  "name": "yacht",
  "version": "0.1.44",
  "private": true,
  "description": "A Luxury Wallet, Your Home for ApeChain.",
  "type": "module",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "prebuild": "node scripts/generate-icons.mjs",
    "predev": "node scripts/generate-icons.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "dev:mobile": "vite --config vite.mobile.config.ts",
    "build:mobile": "tsc -b && vite build --config vite.mobile.config.ts",
    "sync:mobile": "npm run build:mobile && cap sync",
    "ios": "npm run sync:mobile && cap open ios",
    "android": "npm run sync:mobile && cap open android",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "package": "npm run build && node scripts/package.mjs",
    "validate": "node scripts/validate-store-package.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/barcode-scanner": "^3.0.2",
    "@capacitor/core": "^8.3.3",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource/roboto": "^5.2.10",
    "@noble/hashes": "^1.8.0",
    "ethers": "^6.13.4",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/ios": "^8.3.3",
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "rollup": "^4.0.0"
  }
}
